run = "npm run build && node dist/index.js app -p 5000"
entrypoint = "src/web/server.ts"
modules = ["nodejs-20", "web", "bash", "nix"]

[nix]
channel = "stable-25_05"

[deployment]
run = ["node", "dist/index.js", "app", "-p", "5000"]
deploymentTarget = "gce"
build = ["npm", "run", "build"]
publicDir = "dist"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && node dist/index.js app -p 5000"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
